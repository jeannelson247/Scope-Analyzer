{
  "Raw (no conversion)": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "V",
    "formula": "x"
  },
  "Pearson 101 (0.01 V/A)": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "A",
    "formula": "x * 100.0"
  },
  "Pearson 110 (0.1 V/A)": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "A",
    "formula": "x * 10.0"
  },
  "Pearson 1330 / 4418 (0.001 V/A)": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "A",
    "formula": "x * 1000.0"
  },
  "Busbar 100 A/V centered at 2.5 V": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "A",
    "formula": "(x - 2.5) * 200 / 2"
  },
  "Busbar 100 A/V + baseline": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "A",
    "formula": "baseline((x - 2.5) * 200 / 2, t_ms, -1.0)"
  },
  "Busbar 750 A/V centered at 2.5 V": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "A",
    "formula": "(x - 2.5) * 1500 / 2"
  },
  "Busbar 750 A/V reversed": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "A",
    "formula": "-(x - 2.5) * 1500 / 2"
  },
  "Rogowski pre-integrated + baseline": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "V",
    "formula": "baseline(x, t_ms, -1.0)"
  },
  "Rogowski low-pass 10 kHz + baseline": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "V",
    "formula": "baseline(lowpass(x, t, 1e4), t_ms, -1.0)"
  },
  "B-dot integrate after 10 kHz low-pass": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "V*s",
    "formula": "baseline(integrate(lowpass(x, t, 1e4), t, negate=True), t_ms, -1.0)"
  },
  "10x voltage probe": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "V",
    "formula": "x * 10.0"
  },
  "100x HV probe": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "V",
    "formula": "x * 100.0"
  },
