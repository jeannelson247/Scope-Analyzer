  },
  "MATLAB CH3 Rogowski raw V + baseline + 15 kHz LP": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "V",
    "formula": "baseline(lowpass(x, t, 1.5e4), t_ms, -1.0)"
  },
  "MATLAB CH1 busbar 100 A/V + baseline + 10 kHz LP": {
    "gain": 1.0,
    "offset": 0.0,
    "unit": "A",
