/* Scope Studio — v0.2 "Claidev2" refined dark theme.
   Ported from Claidev2/Scope Studio.dc.html (Claude Design redesign).
   Palette (Okabe-Ito / Wong friendly):
     base   #1c1d21   panel  #25262b   elevated #34373e
     border rgba(255,255,255,0.08)
     text   #e8e9ec   text2  #c2c5cc   muted #9a9ca3
     accent #2b8fd6 (Wong blue)   ok #3ec98a   info #7cc1ee
   The plot canvas stays WHITE (pyqtgraph background="w") by design.
   Reversible: original saved as style.qss.bak.* next to this file. */

/* ---- base ------------------------------------------------------------- */
QWidget {
    background: #1c1d21;
    color: #e8e9ec;
    font-family: -apple-system, "SF Pro Text", "Segoe UI", sans-serif;
    font-size: 13px;
}
QMainWindow, QDialog { background: #1c1d21; }
QToolTip {
    background: #25262b; color: #e8e9ec;
    border: 1px solid rgba(255,255,255,0.12); border-radius: 6px; padding: 4px 8px;
}

/* ---- buttons --------------------------------------------------------- */
QPushButton {
    color: #e8e9ec;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 8px;
    padding: 5px 12px;
    background: #2a2c31;
}
QPushButton:hover   { background: #34373e; }
QPushButton:pressed { background: #3a3d45; }
QPushButton:default {
    border: 1px solid #2b8fd6;
    background: rgba(43, 143, 214, 0.22);
}
QPushButton:default:hover { background: rgba(43, 143, 214, 0.34); }
QPushButton:disabled { color: #6f7178; background: #232429; border-color: rgba(255,255,255,0.06); }

/* ---- inputs ---------------------------------------------------------- */
QLineEdit, QPlainTextEdit, QTextEdit, QDoubleSpinBox, QSpinBox, QComboBox {
    background: #202227;
    color: #e8e9ec;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 6px;
    padding: 3px 6px;
    selection-background-color: #2b8fd6;
    selection-color: #ffffff;
}
QLineEdit:focus, QPlainTextEdit:focus, QTextEdit:focus,
QComboBox:focus, QDoubleSpinBox:focus, QSpinBox:focus {
    border: 1px solid #2b8fd6;
}
QComboBox QAbstractItemView {
    background: #25262b; color: #e8e9ec;
    border: 1px solid rgba(255,255,255,0.12);
    selection-background-color: #2b8fd6; selection-color: #ffffff;
    outline: none;
}

/* ---- group boxes as "cards" ----------------------------------------- */
QGroupBox {
    background: #25262b;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 12px;
    margin-top: 14px;
    padding: 10px 12px 8px;
    font-weight: 600;
}
QGroupBox::title {
    subcontrol-origin: margin;
    left: 12px;
    padding: 0 4px;
    color: #9a9ca3;
}

/* ---- tabs (uniform bright inactive font, lifted active bg) ----------- */
QTabWidget::pane {
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 10px;
    background: #202227;
}
QTabBar::tab {
    color: #e7eaf1;                       /* tabInactiveColor — uniform/bright */
    background: #232429;
    border: 1px solid rgba(255,255,255,0.08);
    border-bottom: none;
    border-top-left-radius: 9px;
    border-top-right-radius: 9px;
    padding: 6px 16px;
    margin-right: 2px;
}
QTabBar::tab:hover:!selected { background: #2c2e34; }
QTabBar::tab:selected {
    color: #ffffff;                       /* tabActiveColor */
    background: #34373e;                  /* tabActiveBg — lifted, not dimming others */
    border-color: rgba(255,255,255,0.14);
    font-weight: 600;
}

/* ---- tables --------------------------------------------------------- */
QTableWidget, QTableView {
    background: #202227;
    alternate-background-color: #25262b;
    color: #e8e9ec;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    gridline-color: rgba(255,255,255,0.07);
    selection-background-color: rgba(43,143,214,0.35);
    selection-color: #ffffff;
}
QHeaderView::section {
    background: #25262b;
    color: #9a9ca3;
    border: none;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    padding: 6px 8px;
    font-weight: 600;
}

/* ---- checkboxes / radios -------------------------------------------- */
QCheckBox::indicator, QRadioButton::indicator {
    width: 15px; height: 15px;
    border: 1px solid rgba(255,255,255,0.22);
    border-radius: 4px;
    background: #202227;
}
QRadioButton::indicator { border-radius: 8px; }
QCheckBox::indicator:checked, QRadioButton::indicator:checked {
    background: #2b8fd6;
    border-color: #2b8fd6;
}

/* ---- menus ---------------------------------------------------------- */
QMenuBar { background: #1c1d21; color: #e8e9ec; }
QMenuBar::item:selected { background: #34373e; border-radius: 6px; }
QMenu {
    background: #25262b; color: #e8e9ec;
    border: 1px solid rgba(255,255,255,0.12); border-radius: 8px; padding: 4px;
}
QMenu::item { padding: 5px 22px; border-radius: 6px; }
QMenu::item:selected { background: #2b8fd6; color: #ffffff; }

/* ---- scrollbars (thin, rounded — matches the design) ---------------- */
QScrollBar:vertical   { background: transparent; width: 10px; margin: 2px; }
QScrollBar:horizontal { background: transparent; height: 10px; margin: 2px; }
QScrollBar::handle:vertical, QScrollBar::handle:horizontal {
    background: rgba(255,255,255,0.16);
    border-radius: 5px; min-height: 28px; min-width: 28px;
}
QScrollBar::handle:hover { background: rgba(255,255,255,0.28); }
QScrollBar::add-line, QScrollBar::sub-line { height: 0; width: 0; }
QScrollBar::add-page, QScrollBar::sub-page { background: transparent; }

/* ---- misc chrome ---------------------------------------------------- */
QStatusBar { background: #1c1d21; border-top: 1px solid rgba(255,255,255,0.08); color: #9a9ca3; }
QSplitter::handle { background: rgba(255,255,255,0.06); }
QToolBar { background: #1c1d21; border: none; spacing: 4px; }
QScrollArea { border: none; background: transparent; }
